{
  "name": "scraping-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@scraping-platform/db",
    "db:migrate": "turbo run db:migrate --filter=@scraping-platform/db",
    "db:studio": "turbo run db:studio --filter=@scraping-platform/db"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
