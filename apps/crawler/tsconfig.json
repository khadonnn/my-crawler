{
  "extends": "@apify/tsconfig",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "./src",
    "noUnusedLocals": false,
    "lib": ["DOM"]
  },
  "include": ["./src/**/*"]
}
