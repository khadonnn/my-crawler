generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobSourceType {
  GROUP_URL
  KEYWORD
}

enum InteractionType {
  REACTION
  COMMENT
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

enum JobArtifactType {
  SCREENSHOT
  RAW_EXTRACT
}

enum ProxyRegion {
  ANY
  VN
  US
}

model Job {
  id              String    @id @default(uuid())
  workerJobId     String?   @unique
  sourceType      JobSourceType
  sourceValue     String
  keyword         String?
  requestedProxyRegion ProxyRegion @default(ANY)
  usedProxyId     String?
  usedProxyAddress String?
  usedProxyPort   Int?
  usedProxyRegion ProxyRegion?
  debugMode       Boolean   @default(false)
  status          JobStatus @default(PENDING)
  progress        Int       @default(0)
  leadCount       Int       @default(0)
  processedCount  Int       @default(0)
  errorMessage    String?   @db.Text
  blockedReason   String?   @db.Text
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  updatedAt       DateTime  @updatedAt

  posts           Post[]
  profiles        Profile[]
  interactions    Interaction[]
  artifacts       JobArtifact[]

  @@index([status])
  @@index([sourceType])
}

model JobArtifact {
  id          String          @id @default(uuid())
  jobId        String
  type         JobArtifactType
  path         String
  metadata     Json?
  createdAt    DateTime        @default(now())

  job          Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([type])
}

model Post {
  id              String        @id @default(uuid())
  fbPostId        String        @unique
  postUrl         String
  authorName      String
  content         String?       @db.Text
  keywordMatched  String?
  jobId           String?
  scrapedAt       DateTime      @default(now())

  job             Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  interactions    Interaction[]

  @@index([jobId])
}

model Profile {
  id               String        @id @default(uuid())
  fbUid            String        @unique
  name             String
  profileUrl       String
  gender           String?
  currentCity      String?
  hometown         String?
  workplace        String?
  education        String?
  phone            String?
  email            String?
  instagramUrl     String?
  otherLinks       Json?
  isProfileScraped Boolean       @default(false)
  leadScore        Int           @default(0)
  jobId            String?
  lastUpdated      DateTime      @updatedAt

  job              Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  interactions     Interaction[]

  @@index([jobId])
}

model Interaction {
  id             String          @id @default(uuid())
  type           String
  reactionType   String?
  fbCommentId    String?         @unique
  commentText    String?         @db.Text
  profileId      String
  postId         String
  jobId          String?
  interactedAt   DateTime?
  scrapedAt      DateTime        @default(now())

  job            Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  post           Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([profileId])
  @@index([postId])
  @@unique([profileId, postId, type], name: "unique_reaction")
}

model Proxy {
  id          String   @id @default(uuid())
  address     String
  port        Int
  region      ProxyRegion @default(ANY)
  username    String?
  password    String?
  protocol    String   @default("http")
  status      String   @default("UNKNOWN")
  latency     Int      @default(0)
  lastChecked DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([address, port])
}

model Account {
  id          String   @id @default(cuid())
  platform    String
  name        String
  sessionData Json
  status      String   @default("ACTIVE")
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
