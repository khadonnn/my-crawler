generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id                   String        @id @default(uuid())
  sourceType           JobSourceType
  sourceValue          String
  keyword              String?
  status               JobStatus     @default(PENDING)
  progress             Int           @default(0)
  leadCount            Int           @default(0)
  processedCount       Int           @default(0)
  errorMessage         String?
  createdAt            DateTime      @default(now())
  startedAt            DateTime?
  finishedAt           DateTime?
  updatedAt            DateTime      @updatedAt
  blockedReason        BlockedReason?
  errorDetail          String?
  lastHeartbeatAt      DateTime?
  retryCount           Int           @default(0)
  maxRetry             Int           @default(2)
  retryScheduledFor    DateTime?
  lockedBy             String?
  lockedAt             DateTime?
  debugMode            Boolean       @default(false)
  workerJobId          String?       @unique
  requestedProxyRegion ProxyRegion   @default(ANY)
  usedProxyId          String?
  usedProxyAddress     String?
  usedProxyPort        Int?
  usedProxyRegion      ProxyRegion?
  mode                 CrawlMode     @default(DIRECT_URL)
  platform             Platform      @default(FACEBOOK)
  url                  String?
  searchProgressIndex  Int           @default(0)
  interactions         Interaction[]
  artifacts            JobArtifact[]
  posts                Post[]
  profiles             Profile[]

  @@index([status])
  @@index([sourceType])
}

model JobArtifact {
  id        String          @id @default(uuid())
  jobId     String
  type      JobArtifactType
  path      String
  metadata  Json?
  createdAt DateTime        @default(now())
  job       Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([type])
}

model Post {
  id             String        @id @default(uuid())
  jobId          String?
  fbPostId       String        @unique
  postUrl        String
  authorName     String
  content        String?
  keywordMatched String?
  scrapedAt      DateTime      @default(now())
  interactions   Interaction[]
  job            Job?          @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model Profile {
  id               String        @id @default(uuid())
  jobId            String?
  fbUid            String        @unique
  name             String
  profileUrl       String
  gender           String?
  currentCity      String?
  hometown         String?
  workplace        String?
  education        String?
  instagramUrl     String?
  otherLinks       Json?
  isProfileScraped Boolean       @default(false)
  leadScore        Int           @default(0)
  lastUpdated      DateTime      @updatedAt
  email            String?
  phone            String?
  interactions     Interaction[]
  job              Job?          @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model Interaction {
  id           String    @id @default(uuid())
  jobId        String?
  commentText  String?
  profileId    String
  postId       String
  interactedAt DateTime?
  scrapedAt    DateTime  @default(now())
  fbCommentId  String?   @unique
  type         String
  reactionType String?
  job          Job?      @relation(fields: [jobId], references: [id])
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, postId, type], name: "unique_reaction")
  @@index([jobId])
  @@index([profileId])
  @@index([postId])
}

model Proxy {
  id          String      @id @default(uuid())
  address     String
  port        Int
  username    String?
  password    String?
  protocol    String      @default("http")
  status      String      @default("UNKNOWN")
  latency     Int         @default(0)
  lastChecked DateTime    @default(now())
  createdAt   DateTime    @default(now())
  region      ProxyRegion @default(ANY)
  countryCode  String   @default("UNKNOWN")
  @@unique([address, port])
}

model Account {
  id          String    @id @default(cuid())
  platform    String
  name        String
  sessionData Json
  status      String    @default("ACTIVE")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobSourceType {
  GROUP_URL
  KEYWORD
}

enum InteractionType {
  REACTION
  COMMENT
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

enum JobArtifactType {
  SCREENSHOT
  RAW_EXTRACT
}

enum ProxyRegion {
  ANY
  VN
  US
}

enum Platform {
  FACEBOOK
  GOOGLE
  YOUTUBE
  TIKTOK
}

enum CrawlMode {
  DIRECT_URL
  SEARCH_KEYWORD
}

enum BlockedReason {
  LOGIN_WALL
  CAPTCHA
  TIMEOUT
  NETWORK_ERROR
  NO_HEARTBEAT
  EXTRACTION_LIMIT
  NO_PROXY_IN_POOL
  NO_PROXY_AVAILABLE
  PROXY_REQUIRED
  IP_LEAK_DETECTED
  IP_VERIFICATION_FAILED
  UNKNOWN
}
